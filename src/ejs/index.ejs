<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mockup Starter</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Noto+Serif+JP:wght@600&family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="./assets/css/style.css" />
  </head>
  <body class="bg-brand-bg font-sans text-black/90 antialiased">
<%- include("./partials/_header") %>

    <main>
      <!-- MainVisualSection -->
      <section class="bg-brand-bg px-sp-section-x py-sp-section-y md:px-8 md:py-16">
        <div class="mx-auto grid max-w-content gap-8 md:grid-cols-[1fr_1.2fr] md:items-center">
          <div>
            <p class="mb-3 text-sm font-bold uppercase tracking-wide text-link-muted">Mockup Starter</p>
            <h1 class="font-serif text-3xl font-semibold leading-tight md:text-5xl">Figma MCPから静的モックアップを作るスターター</h1>
            <p class="mt-5 max-w-xl text-sm leading-7 text-black/70 md:text-base">
              EJS、SCSS、Tailwind CSS、Chrome MCPレビューを組み合わせた制作用テンプレートです。
            </p>
          </div>
          <div class="aspect-video overflow-hidden rounded-lg bg-white shadow-sm">
            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-white to-stone-200 text-sm font-bold text-black/50">
              Visual Placeholder
            </div>
          </div>
        </div>
      </section>

      <!-- SampleSection -->
      <section class="bg-white px-sp-section-x py-sp-section-y md:px-8 md:py-16">
        <div class="mx-auto max-w-content">
          <header class="mb-8 flex flex-wrap items-end justify-between gap-4">
            <div>
              <p class="text-sm font-bold uppercase tracking-wide text-link-muted">SECTION</p>
              <h2 class="mt-2 text-2xl font-bold md:text-4xl">セクションサンプル</h2>
            </div>
            <a href="#" class="text-sm font-bold text-link-muted transition hover:text-black">一覧を見る</a>
          </header>

          <div class="grid grid-cols-2 gap-sp-gap-md md:grid-cols-4 md:gap-6">
            <% for (let i = 1; i <= 4; i++) { %>
              <article class="group">
                <a href="#" class="block">
                  <div class="aspect-square overflow-hidden rounded bg-brand-bg">
                    <div class="flex h-full w-full items-center justify-center text-sm font-bold text-black/40 transition duration-300 group-hover:scale-subtle">
                      Image <%= i %>
                    </div>
                  </div>
                  <h3 class="mt-3 text-sm font-bold leading-6 md:text-base">カードタイトル <%= i %></h3>
                  <p class="mt-1 text-xs leading-5 text-black/60 md:text-sm">カード説明テキストが入ります。</p>
                </a>
              </article>
            <% } %>
          </div>
        </div>
      </section>
    </main>

    <script src="./assets/js/main.js"></script>
  </body>
</html>
