{
  "name": "mockup-starter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:ejs": "ejs ./src/ejs/index.ejs -o ./index.html",
    "build:scss": "sass ./src/scss/input.scss ./.tmp/input.css --no-source-map",
    "build:css": "tailwindcss -i ./.tmp/input.css -o ./assets/css/style.css",
    "build": "npm run build:ejs && npm run build:scss && npm run build:css",
    "watch:ejs": "chokidar \"src/ejs/**/*.ejs\" -c \"npm run build:ejs\"",
    "watch:scss": "sass ./src/scss/input.scss ./.tmp/input.css --watch --no-source-map",
    "watch:css": "tailwindcss -i ./.tmp/input.css -o ./assets/css/style.css --watch",
    "watch": "npm run build && concurrently \"npm:watch:ejs\" \"npm:watch:scss\" \"npm:watch:css\""
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "ejs": "^6.0.1",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.17"
  }
}
